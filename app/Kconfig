menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default y
    help
        Enable the LED subsystem configuration menu.

if LED_SUBSYSTEM

choice
    prompt "LED blink sleep time"
    default LED_BLINK_SLEEP_1S
    help
        Select the LED blink delay preset.
config LED_BLINK_SLEEP_15MS
    bool "15ms very fast"

config LED_BLINK_SLEEP_250MS
    bool "250ms (fast)"

config LED_BLINK_SLEEP_500MS
    bool "500ms"

config LED_BLINK_SLEEP_1S
    bool "1s (medium)"

config LED_BLINK_SLEEP_2S
    bool "2s (slow)"

endchoice

config LED_BLINK_SLEEP_TIME_MS
    int
    default 15 if LED_BLINK_SLEEP_15MS
    default 250 if LED_BLINK_SLEEP_250MS
    default 500 if LED_BLINK_SLEEP_500MS
    default 1000 if LED_BLINK_SLEEP_1S
    default 2000 if LED_BLINK_SLEEP_2S
    help
        Hidden integer value derived from the selected blink sleep preset.

menuconfig ADVANCED_LED_SETTINGS
    bool "Advanced LED settings"
    help
        Enable access to advanced LED tuning options.

if ADVANCED_LED_SETTINGS

config LED_BRIGHTNESS
    int "LED brightness"
    default 100
    range 0 100
    help
        LED brightness percentage.

config LED_FADE_DURATION_MS
    int "LED fade duration (ms)"
    default 500
    range 0 5000
    help
        Fade duration in milliseconds.

menu "Expert settings"
    visible if ADVANCED_LED_SETTINGS

config LED_DEBUG
    bool "Enable LED debugging"

config LED_CUSTOM_BLINK_PATTERN
    bool "Custom blink pattern"

endmenu

endif

endif

config APP_HEARTBEAT_PERIOD_MS
    int "Heartbeat LED period in milliseconds"
    default 500
    range 100 2000
    help
      Controls the blink period of the heartbeat LED in milliseconds.

source "Kconfig.zephyr"
