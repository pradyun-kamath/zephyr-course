/*
 * Board overlay for Nucleo U575ZI-Q
 *
 * The Nucleo U575ZI-Q has built-in user LEDs exposed by the board DTS.
 * For this exercise an external red LED is wired to the D12 header pin
 * (PA6), matching the Nucleo F446RE wiring. We introduce a dedicated
 * `app-led` alias that the application code resolves with DT_ALIAS(app_led).
 */

/ {
	leds {
		compatible = "gpio-leds";

		/* External red LED connected to D12 (PA6) */
		red_led: red_led_0 {
			gpios = <&gpioa 6 GPIO_ACTIVE_HIGH>;
			label = "External Red LED (D12 / PA6)";
		};
	};

	aliases {
		app-led = &red_led;
	};
};
